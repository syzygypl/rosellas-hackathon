# Backend
PORT=8080
CORS_ORIGIN=http://localhost:4200

# TRIZ MCP server (streamable HTTP, JSON-RPC)
MCP_URL=http://localhost:8123/mcp

# Optional: LLM enrichment of candidate solutions.
# Leave empty to run purely on the TRIZ MCP (fully working without any LLM).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Deep Agent chat (POST /api/chat, POST /api/agent/solve). Without the key the
# chat falls back to the LLM-free pipeline and returns a configuration warning.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
