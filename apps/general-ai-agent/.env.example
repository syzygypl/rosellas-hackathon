# Backend
BACKEND_PORT=8080
CORS_ORIGIN=http://localhost:4200
LOG_LEVEL=INFO

# TRIZ MCP server (streamable HTTP, JSON-RPC)
MCP_URL=http://localhost:8123/mcp

# SCAMPER MCP server (streamable HTTP, JSON-RPC)
SCAMPER_MCP_URL=http://localhost:8124/mcp

# Optional: LLM enrichment of candidate solutions.
# Leave empty to run purely on the TRIZ MCP (fully working without any LLM).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Deep Agent chat (POST /api/chat, POST /api/agent/solve). The backend checks
# OPENAI_API_KEY, then EMBEDDING_API_KEY, then legacy OPEN_AI_API_KEY. Without a
# compatible key the chat falls back to the LLM-free pipeline and returns a
# configuration warning.
OPENAI_API_KEY=
EMBEDDING_API_KEY=
OPEN_AI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low

# Optional: Langfuse tracing for backend AI flows. When both keys are set, the
# backend traces chat/agent/pipeline calls, LangChain runs, and MCP tool calls.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=local
LANGCHAIN_CALLBACKS_BACKGROUND=false
