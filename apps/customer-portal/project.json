{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "customer-portal",
  "projectType": "application",
  "root": "apps/customer-portal",
  "sourceRoot": "apps/customer-portal/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist/customer-portal"
      ],
      "options": {
        "cwd": "apps/customer-portal",
        "command": "../../node_modules/.bin/ng build --configuration production"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/customer-portal",
        "command": "../../node_modules/.bin/ng serve"
      }
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/customer-portal",
        "command": "../../node_modules/.bin/ng build --watch --configuration development"
      }
    }
  }
}
