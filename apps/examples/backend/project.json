{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "backend",
  "projectType": "application",
  "root": "apps/examples/backend",
  "sourceRoot": "apps/examples/backend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "apps/examples/backend",
        "command": "../../../node_modules/.bin/nest build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/examples/backend",
        "command": "../../../node_modules/.bin/nest start --watch"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/examples/backend",
        "command": "../../../node_modules/.bin/nest start"
      }
    }
  }
}
