{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "frontend",
  "projectType": "application",
  "root": "frontend",
  "sourceRoot": "frontend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist/crud-frontend"
      ],
      "options": {
        "cwd": "frontend",
        "command": "npm run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "frontend",
        "command": "npm start"
      }
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "frontend",
        "command": "npm run watch"
      }
    }
  }
}
