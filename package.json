{
  "name": "rosellas-hackathon",
  "version": "1.0.0",
  "description": "Rosellas Hackathon Nx workspace",
  "private": true,
  "scripts": {
    "nx": "nx",
    "build": "nx run-many --target=build --projects=general-ai-agent,customer-portal,triz-mcp-server,landing-page",
    "build:ai-agent": "nx run-many --target=build --projects=general-ai-agent,customer-portal,triz-mcp-server",
    "build:backend": "nx run general-ai-agent:build",
    "build:example-backend": "nx run backend:build",
    "build:example-frontend": "nx run frontend:build",
    "build:frontend": "nx run customer-portal:build",
    "build:mcp": "nx run triz-mcp-server:build",
    "build:landing": "nx run landing-page:build",
    "start:ai-agent": "nx run-many --target=serve --projects=general-ai-agent,customer-portal --parallel=2",
    "start:backend": "nx run general-ai-agent:serve",
    "start:example-backend": "nx run backend:serve",
    "start:example-frontend": "nx run frontend:serve",
    "start:frontend": "nx run customer-portal:serve",
    "start:mcp": "nx run triz-mcp-server:serve",
    "start:landing": "nx run landing-page:serve",
    "graph": "nx graph"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.5.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "deepagents": "^1.10.5",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.0.6",
    "@angular/animations": "19.0.5",
    "@angular/cli": "19.0.6",
    "@angular/common": "19.0.5",
    "@angular/compiler": "19.0.5",
    "@angular/compiler-cli": "19.0.5",
    "@angular/core": "19.0.5",
    "@angular/forms": "19.0.5",
    "@angular/platform-browser": "19.0.5",
    "@angular/platform-browser-dynamic": "19.0.5",
    "@angular/router": "19.0.5",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "nx": "^23.0.1",
    "tslib": "^2.8.1",
    "typescript": "~5.6.3",
    "zone.js": "~0.15.0"
  },
  "optionalDependencies": {
    "@nx/nx-linux-x64-gnu": "23.0.1"
  }
}
