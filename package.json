{
  "name": "inventive-solver",
  "version": "0.1.0",
  "description": "Inventive Problem Solver MVP — NestJS backend over the TRIZ MCP server",
  "private": true,
  "scripts": {
    "start": "ts-node src/main.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/prompts && cp src/prompts/*.md dist/prompts/",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.5.3",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "deepagents": "^1.10.5",
    "dotenv": "^16.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
